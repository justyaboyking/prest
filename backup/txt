    <!-- Initialize Icons & Scroll Animations -->
    <script>
        // Init Lucide Icons
        lucide.createIcons();

        // Scroll Animations observer (Verbeterd)
        const observerOptions = {
            root: null,
            rootMargin: '0px 0px -10% 0px', // Activeert net iets voordat het element 100% in beeld is
            threshold: 0.1
        };

        const observer = new IntersectionObserver((entries, observer) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                    // Optioneel: unobserve als je wil dat de animatie maar 1x gebeurt. 
                    // Voor een dynamischer effect laten we hem observeren zodat het opnieuw animeert bij terug scrollen.
                    observer.unobserve(entry.target); 
                }
            });
        }, observerOptions);

        // Selecteer alle elementen met de base class 'reveal-element'
        document.querySelectorAll('.reveal-element').forEach((el) => {
            observer.observe(el);
        });

        // Navbar blur effect on scroll
        window.addEventListener('scroll', () => {
            const nav = document.getElementById('navbar');
            if (window.scrollY > 20) {
                nav.classList.add('shadow-md');
                nav.classList.replace('bg-transparent', 'glass-nav');
            } else {
                nav.classList.remove('shadow-md');
            }
        });
    </script>
